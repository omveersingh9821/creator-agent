# ─── LLM Provider ───
# Options: "gemini", "openai", or "anthropic"
LLM_PROVIDER=gemini

# ─── Google Gemini ───
GOOGLE_API_KEY=your-google-api-key-here

# ─── OpenAI (only needed if LLM_PROVIDER=openai) ───
OPENAI_API_KEY=your-openai-api-key-here

# ─── Anthropic (only needed if LLM_PROVIDER=anthropic) ───
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Nano Banana (Image Generation) ───
NANO_BANANA_API_KEY=your-nano-banana-api-key-here

# ─── Model Configuration ───
MODEL_NAME=gemini-2.0-flash
TEMPERATURE=0.7

# ─── MongoDB ───
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/creator_agent?retryWrites=true&w=majority

# ─── Firebase (used by Vite frontend, must start with VITE_) ───
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
